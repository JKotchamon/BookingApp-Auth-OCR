# HBMS Environment Configuration Template
# Copy this file to .env and fill in your actual secrets

# Database Configuration
DB_HOST=mysql
DB_USER=root
DB_PASS=your_strong_password_here
DB_NAME=hbmsdb

# OAuth Credentials (Google)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth Credentials (Microsoft)
MS_CLIENT_ID=your_ms_client_id_here
MS_CLIENT_SECRET=your_ms_client_secret_here

# Security & Encryption
# IMPORTANT: Generate a 32-character random string for the encryption key
HBMS_ENCRYPTION_KEY=your_32_character_secret_key_here
HBMS_HMAC_KEY=your_hmac_secret_key_here

# Application Settings
APP_URL=http://localhost:8080
